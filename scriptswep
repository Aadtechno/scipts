ExecStart=/bin/bash /home/roe/roeReportFileSweeperScript/roeReportFileSweeper.sh \
  -g gs://ews-iws-can-prd-roe-data-factory \
  -a gs://ews-iws-can-prd-roe-archive-data-factory \
  -d roeReport \
  -l /mnt/disks/data/twni/roe/ROESAT/sftsectran20/wds/users/0004-00001/511/Active/0004-00000136/in

Restart=always
RestartSec=10
KillMode=process
TimeoutStopSec=30

